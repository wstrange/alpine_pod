    "version": "0.2.0",
    "configurations": [

        {
            "name": "Flutter Web",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "cwd": "alpine_pod_flutter",
            "args": [
                "--web-port",
                "56804"
            ]
        },
        {
            "name": "alpine_pod_client",
            "cwd": "alpine_pod_client",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "alpine_pod_flutter",
            "cwd": "alpine_pod_flutter",
            "request": "launch",
            "type": "dart",
            "args": ["--web-port", "56804"]
        },
        {
            "name": "alpine_pod_flutter (profile mode)",
            "cwd": "alpine_pod_flutter",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "args": ["--web-port", "56804"]
        },
        {
            "name": "alpine_pod_flutter (release mode)",
            "cwd": "alpine_pod_flutter",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {
            "name": "alpine_pod_server",
            "cwd": "alpine_pod_server",
            "request": "launch",
            "type": "dart"
        }
    ]
}